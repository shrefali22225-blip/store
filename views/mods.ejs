<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Products – SwatVapeStore</title>
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #0A0A0A; font-family: "Roboto", sans-serif; color: #e6e6e6; min-height: 100vh; }

        .allProudctConteiner { display: flex; gap: 20px; max-width: 1200px; margin: 24px auto; padding: 0 16px; align-items: flex-start; }

        /* Filter */
        .filter_conteiner { background: rgba(57,67,87,0.2); border: 0.5px solid rgba(255,255,255,0.07); border-radius: 12px; box-shadow: inset 0px 2px 2px 2px rgba(0,0,255,0.10); padding: 20px; min-width: 210px; position: sticky; top: 20px; max-width: 356px; }
        .filter_conteiner h1 { font-size: 15px; font-weight: 500; color: #f5f5f5; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 0.5px solid rgba(255,255,255,0.08); }
        .priceFilterSpan { display: block; font-size: 11px; color: #888; margin-bottom: 8px; margin-top: 16px; text-transform: uppercase; letter-spacing: 0.5px; }
        .priceFilterInputs { display: flex; gap: 8px; }
        .priceFilterInputMin, .priceFilterInputMax { width: 100%; padding: 8px 10px; background: rgba(0,0,0,0.4); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 7px; color: #f0f0f0; font-size: 13px; font-family: inherit; transition: border-color 0.2s; }
        .priceFilterInputMin:focus, .priceFilterInputMax:focus { outline: none; border-color: #0077ff; }
        .modelName { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
        .modelName button { padding: 6px 14px; border-radius: 7px; border: 0.5px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.3); color: #b8b8b8; font-size: 12px; font-family: inherit; cursor: pointer; transition: all 0.2s; }
        .modelName button:hover, .modelName button.active { background: rgba(66,154,212,0.87); color: #fff; border-color: transparent; }
        .filter-apply-btn { width: 100%; margin-top: 16px; padding: 9px; background: rgba(66,154,212,0.87); color: #fff; border: none; border-radius: 8px; font-size: 13px; font-family: inherit; cursor: pointer; transition: background 0.2s; }
        .filter-apply-btn:hover { background: aqua; color: #000; }
        .filterBtn_box { display: none; }

        /* Grid */
        .product-parent { flex: 1; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 18px; align-content: start; }

        /* ts-card */
        .ts-card { background: rgba(57,67,87,0.2); border: 0.5px solid rgba(255,255,255,0.07); border-radius: 12px; overflow: hidden; transition: border-color 0.2s, transform 0.2s; display: flex; flex-direction: column; }
        .ts-card:hover { border-color: color-mix(in srgb, var(--c) 45%, transparent); transform: translateY(-3px); }
        .ts-card__media { position: relative; aspect-ratio: 1/1; background: #0f0f10; overflow: hidden; }
        .ts-card__bg { position: absolute; inset: 0; background: radial-gradient(circle at 70% 30%, color-mix(in srgb, var(--c) 18%, transparent), transparent 65%); pointer-events: none; }
        .ts-card__imgwrap { display: block; width: 100%; height: 100%; }
        .ts-card__imgwrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s ease; display: block; }
        .ts-card:hover .ts-card__imgwrap img { transform: scale(1.05); }
        .ts-card__top { position: absolute; top: 10px; left: 10px; right: 10px; display: flex; justify-content: space-between; align-items: center; }
        .ts-badge { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; letter-spacing: 0.5px; padding: 3px 8px; border-radius: 6px; }
        .ts-badge--new { background: rgba(92,200,255,0.15); color: #5cc8ff; border: 0.5px solid rgba(92,200,255,0.3); }
        .ts-badge--hot { background: rgba(255,107,107,0.15); color: #ff6b6b; border: 0.5px solid rgba(255,107,107,0.3); }
        .ts-fav { width: 28px; height: 28px; background: rgba(15,15,16,0.7); border: 0.5px solid rgba(255,255,255,0.1); border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 13px; color: #b8b8b8; transition: all 0.2s; }
        .ts-fav:hover, .ts-fav.is-active { color: #ff5c5c; border-color: rgba(255,92,92,0.4); }
        .ts-card__cta { position: absolute; bottom: 0; left: 0; right: 0; padding: 10px; background: linear-gradient(to top, rgba(15,15,16,0.92) 0%, transparent 100%); transform: translateY(100%); transition: transform 0.25s ease; }
        .ts-card:hover .ts-card__cta { transform: translateY(0); }
        .ts-card__cta .buy_btn { width: 100%; padding: 10px; background: rgba(66,154,212,0.87); color: #fff; font-size: 14px; font-weight: 500; border: none; border-radius: 7px; cursor: pointer; transition: background 0.2s; display: flex; align-items: center; justify-content: center; gap: 6px; font-family: inherit; }
        .ts-card__cta .buy_btn:hover:not(:disabled) { background: aqua; color: #000; }
        .ts-card__cta .buy_btn:disabled { background: #3a3a3d; color: #666; cursor: not-allowed; }
        .ts-card__info { padding: 14px 16px 16px; display: flex; flex-direction: column; gap: 5px; flex: 1; }
        .ts-card__row { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
        .ts-card__row--end { margin-top: auto; padding-top: 6px; }
        .ts-brand { font-size: 12px; font-weight: 600; color: var(--c); text-decoration: none; text-transform: uppercase; letter-spacing: 0.4px; }
        .ts-stock { font-size: 11px; color: #888; display: flex; align-items: center; gap: 3px; }
        .ts-stock[data-stock="0"] { color: #ff6b6b; }
        .ts-name { font-size: 14px; font-weight: 500; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .ts-name a { color: #f0f0f0; text-decoration: none; }
        .ts-name a:hover { color: var(--c); }
        .ts-price__now { font-size: 17px; font-weight: 500; color: #E0A75E; }
        .ts-bar { flex: 1; height: 2px; background: color-mix(in srgb, var(--c) 30%, transparent); border-radius: 99px; }

        /* Skeleton */
        .ts-skeleton { background: rgba(57,67,87,0.15); border-radius: 12px; border: 0.5px solid rgba(255,255,255,0.06); overflow: hidden; animation: tsPulse 1.5s ease-in-out infinite; }
        .ts-skeleton__img { aspect-ratio: 1/1; background: #232326; }
        .ts-skeleton__body { padding: 12px; display: flex; flex-direction: column; gap: 8px; }
        .ts-skeleton__line { height: 10px; border-radius: 4px; background: #2a2a2e; }
        .ts-skeleton__line--sm { width: 60%; }
        @keyframes tsPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.45; } }

        /* Empty */
        .empty-state { grid-column: 1/-1; text-align: center; padding: 60px 20px; color: #555; }
        .empty-state i { font-size: 48px; margin-bottom: 16px; display: block; }

        /* Back to top */
        .back-to-top-btn { position: fixed; bottom: 110px; right: 20px; z-index: 99; }
        .topBtn { width: 40px; height: 40px; background: rgba(66,154,212,0.87); border: none; border-radius: 8px; color: #fff; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
        .topBtn:hover { background: aqua; color: #000; }

        /* Footer */
        .footer { background: #111113; border-top: 0.5px solid rgba(255,255,255,0.07); padding: 20px 16px; display: flex; flex-direction: column; align-items: center; gap: 12px; margin-top: 48px; }
        .copyRight p { font-size: 12px; color: #666; }
        .socialMadiaLinks ul { display: flex; list-style: none; gap: 14px; }
        .socialMadiaLinks a { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; background: rgba(57,67,87,0.3); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 7px; color: #b8b8b8; font-size: 15px; transition: all 0.2s; text-decoration: none; }
        .socialMadiaLinks a:hover { background: #0077ff; border-color: #0077ff; color: #fff; }

        /* Responsive */
        @media (max-width: 768px) {
            .filter_conteiner { display: none; }
            .filter_conteiner.open { display: block; position: fixed; inset: 0; z-index: 200; border-radius: 0; overflow-y: auto; }
            .filterBtn_box { display: flex; gap: 10px; margin-bottom: 12px; }
            .openFilters { padding: 8px 16px; background: rgba(66,154,212,0.87); border: none; border-radius: 8px; color: #fff; font-size: 13px; font-family: inherit; cursor: pointer; }
            .product-parent { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
            .allProudctConteiner { flex-direction: column; }
        }
    </style>
</head>

<body>

<%- include('component/navbar') %>

<div class="allProudctConteiner">

    <div class="filterBtn_box">
        <button class="openFilters"><i class="fa-solid fa-bars-filter"></i> Filter</button>
    </div>

    <div class="filter_conteiner miniDeviceFilter">
        <div class="filter_box">
            <h1><i class="fa-solid fa-sliders" style="color:#0077ff;margin-right:6px;"></i>Product Filter</h1>
            <div class="priceFilterBox">
                <span class="priceFilterSpan">Filter by Price</span>
                <div class="priceFilterInputs">
                    <input class="priceFilterInputMin" type="number" placeholder="Min">
                    <input class="priceFilterInputMax" type="number" placeholder="Max">
                </div>
                <div class="brandFilterbox">
                    <span class="priceFilterSpan">Filter by Brand</span>
                    <div class="modelName">
                       <button class="brand-filter active" data-brand="all">All</button>

<% brands.forEach(brand => { %>
    <button class="brand-filter" data-brand="<%= brand %>">
        <%= brand %>
    </button>
<% }) %>
                    </div>
                </div>
                <button class="filter-apply-btn">
                    <i class="fa-solid fa-magnifying-glass"></i> Apply Filter
                </button>
            </div>
        </div>
    </div>

    <!-- ⬇️ غيّر /products/all للـ route الصح عندك -->
    <div class="product-parent" data-fetch="/add/mod/proudct/on/page">
        <div class="ts-skeleton"><div class="ts-skeleton__img"></div><div class="ts-skeleton__body"><div class="ts-skeleton__line ts-skeleton__line--sm"></div><div class="ts-skeleton__line"></div><div class="ts-skeleton__line ts-skeleton__line--sm"></div></div></div>
        <div class="ts-skeleton"><div class="ts-skeleton__img"></div><div class="ts-skeleton__body"><div class="ts-skeleton__line ts-skeleton__line--sm"></div><div class="ts-skeleton__line"></div><div class="ts-skeleton__line ts-skeleton__line--sm"></div></div></div>
        <div class="ts-skeleton"><div class="ts-skeleton__img"></div><div class="ts-skeleton__body"><div class="ts-skeleton__line ts-skeleton__line--sm"></div><div class="ts-skeleton__line"></div><div class="ts-skeleton__line ts-skeleton__line--sm"></div></div></div>
        <div class="ts-skeleton"><div class="ts-skeleton__img"></div><div class="ts-skeleton__body"><div class="ts-skeleton__line ts-skeleton__line--sm"></div><div class="ts-skeleton__line"></div><div class="ts-skeleton__line ts-skeleton__line--sm"></div></div></div>
        <div class="ts-skeleton"><div class="ts-skeleton__img"></div><div class="ts-skeleton__body"><div class="ts-skeleton__line ts-skeleton__line--sm"></div><div class="ts-skeleton__line"></div><div class="ts-skeleton__line ts-skeleton__line--sm"></div></div></div>
        <div class="ts-skeleton"><div class="ts-skeleton__img"></div><div class="ts-skeleton__body"><div class="ts-skeleton__line ts-skeleton__line--sm"></div><div class="ts-skeleton__line"></div><div class="ts-skeleton__line ts-skeleton__line--sm"></div></div></div>
    </div>

</div>

<div class="back-to-top-btn">
    <button class="topBtn"><i class="fa-solid fa-arrow-up"></i></button>
</div>

<footer class="footer">
    <div class="copyRight">
        <p>Copyright &copy; 2024 SwatVapeStore. All rights reserved.</p>
    </div>
    <div class="socialMadiaLinks">
        <ul>
            <li><a href=""><i class="fa-brands fa-facebook"></i></a></li>
            <li><a href=""><i class="fa-brands fa-x-twitter"></i></a></li>
            <li><a href=""><i class="fa-brands fa-whatsapp"></i></a></li>
            <li><a href=""><i class="fa-brands fa-linkedin"></i></a></li>
        </ul>
    </div>
</footer>

<script src="/public/js/device.js"></script>
<script src="/public/js/Cart.js"></script>
<script src="/public/js/searchBar.js" defer></script>
<script src="/public/js/MenuBar.js"></script>
<script src="/public/js/upBtn.js"></script>
<script></script>

<script>
(function () {
    const PALETTE = ['#5cc8ff', '#b388ff', '#ffb86b', '#5cffb8', '#ff7ad9', '#ff5c5c', '#fcd34d'];

    function cardHTML(p, idx) {
        const color    = PALETTE[idx % PALETTE.length];
        const outOfStk = Number(p.stock) <= 0;
        const stockTxt = outOfStk ? 'Out of stock' : `In stock: ${p.stock}`;
        return `
            <article class="ts-card" style="--c:${color}"
                data-brand="${(p.brand || '').toLowerCase()}"
                data-price="${p.price}">
                <div class="ts-card__media">
                    <div class="ts-card__bg"></div>
                    <a href="${p.link}" class="ts-card__imgwrap">
                        <img src="/img/${p.image}" alt="${p.name}"
                             onerror="this.src='https://via.placeholder.com/300x300?text=No+Image'" />
                    </a>
                    <div class="ts-card__top">
                        <span class="ts-badge ${outOfStk ? 'ts-badge--hot' : 'ts-badge--new'}">
                            <i class="fa-solid ${outOfStk ? 'fa-ban' : 'fa-bolt'}"></i>
                            ${outOfStk ? 'SOLD OUT' : 'IN STOCK'}
                        </span>
                        <button class="ts-fav" aria-label="favorite"><i class="fa-regular fa-heart"></i></button>
                    </div>
                    <div class="ts-card__cta">
                        <button class="buy_btn"
                                data-id="${p.id}" data-name="${p.name}"
                                data-price="${p.price}" data-img="${p.image}"
                                data-stock="${p.stock}" ${outOfStk ? 'disabled' : ''}>
                            <i class="fa-solid fa-cart-shopping"></i>
                            ${outOfStk ? 'Unavailable' : 'Add To Cart'}
                        </button>
                    </div>
                </div>
                <div class="ts-card__info">
                    <div class="ts-card__row">
                        <a class="ts-brand" href="${p.brandLink || '#'}">${p.brand}</a>
                        <span class="ts-stock" data-stock="${p.stock}">
                            <i class="fa-solid fa-box"></i> ${stockTxt}
                        </span>
                    </div>
                    <h3 class="ts-name"><a href="${p.link}">${p.name}</a></h3>
                    <div class="ts-card__row ts-card__row--end">
                        <span class="ts-price__now">${Number(p.price).toLocaleString()} EGP</span>
                        <span class="ts-bar"></span>
                    </div>
                </div>
            </article>`;
    }

    const grid = document.querySelector('.product-parent');
    const url  = grid?.dataset.fetch;
    let allProducts = [];

    function renderCards(products) {
        if (!products.length) {
            grid.innerHTML = `<div class="empty-state"><i class="fa-solid fa-box-open"></i><p>No products match your filters.</p></div>`;
            return;
        }
        grid.innerHTML = products.map((p, i) => cardHTML(p, i)).join('');
        if (typeof updateStockUI === 'function') updateStockUI();
    }

    if (url) {
        fetch(url)
            .then(r => r.json())
            .then(data => {
                allProducts = data;
                renderCards(allProducts);
                grid.addEventListener('click', e => {
                    const fav = e.target.closest('.ts-fav');
                    if (!fav) return;
                    fav.classList.toggle('is-active');
                    fav.querySelector('i').classList.toggle('fa-regular');
                    fav.querySelector('i').classList.toggle('fa-solid');
                });
            })
            .catch(() => {
                grid.innerHTML = `<div class="empty-state"><i class="fa-solid fa-triangle-exclamation"></i><p>Failed to load products.</p></div>`;
            });
    }

    let activeBrand = 'all';
    document.querySelectorAll('.brand-filter').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.brand-filter').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activeBrand = btn.dataset.brand;
        });
    });

    document.querySelector('.filter-apply-btn')?.addEventListener('click', () => {
        const minVal = parseFloat(document.querySelector('.priceFilterInputMin').value) || 0;
        const maxVal = parseFloat(document.querySelector('.priceFilterInputMax').value) || Infinity;
        renderCards(allProducts.filter(p => {
            const price   = Number(p.price);
            const brandOk = activeBrand === 'all' || (p.brand || '').toLowerCase() === activeBrand.toLowerCase();
            return brandOk && price >= minVal && price <= maxVal;
        }));
    });

    document.querySelector('.openFilters')?.addEventListener('click', () => {
        document.querySelector('.filter_conteiner')?.classList.toggle('open');
    });

    document.querySelector('.topBtn')?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });
})();
</script>

</body>
</html>